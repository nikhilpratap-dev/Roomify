<% layout("layouts/boilerplate")%>
<body>
    <form method="POST" action="/listing/<%=listing._id%>/update?_method=PUT" class="needs-validation" novalidate>
        <h3>give information for new listings</h3>
        <div class="row">
            <div class="col-8 offset-2">
        <div class="mt-3">
             <label for="title" class="form-label">Title</label>
            <input value="<%=listing.title%>" name="listing[title]" type="text" class="form-control" required>
            <div class="invalid-feedback">Enter a valid title</div>
        </div>
        <div class="mt-3">
             <label for="description" class="form-label">Description</label>
            <input value="<%=listing.description%>" name="listing[description]" type="text" class="form-control" required>
            <div class="invalid-feedback">please valid description</div>
        </div>
        <div class="mt-3">
             <label for="price" class="form-label">Price</label>
            <input value="<%=listing.price%>" name="listing[price]" type="number" class="form-control" required>
            <div class="invalid-feedback">enter a valid price</div>
        </div>
        <div class="mt-3">
             <label for="image" class="form-label">Image</label>
            <input value="<%=listing.image%>" name="listing[image]" type="url" class="form-control" required>
            <div class="invalid-feedback">give valid url</div>
        </div>
        <div class="mt-3">
             <label for="location" class="form-label">Location</label>
            <input value="<%=listing.location%>" name="listing[location]" type="text" class="form-control" required>
            <div class="invalid-feedback">give valid location</div>
        </div>
        <div class="mt-3">
             <label for="country" class="form-label">Country</label>
            <input value="<%=listing.country%>" name="listing[country]" type="text" class="form-control" required>
            <div class="invalid-feedback"> give valid country</div>
        </div>
        
        
        <button class="mt-3 mb-3">update</button>
        </div>
        </div>
    </form>
</body>