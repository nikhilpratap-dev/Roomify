<% layout("layouts/boilerplate") %>
<body>
    <form method="POST" action="/listing/new/add" class="needs-validation" novalidate enctype="multipart/form-data">
        <h3>give information for new listings</h3>
        <div class="row">
            <div class="col-8 offset-2">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input placeholder="give title" name="listing[title]" type="text" class="form-control" required>
            <div class="invalid-feedback"> give the title</div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea placeholder="give description" name="listing[description]" class="form-control" required></textarea>
            <div class="invalid-feedback"> give the description</div>
        </div>
        
        <div class="row">
            <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input placeholder="give price" name="listing[price]" class="form-control" required>
            <div class="invalid-feedback">enter the price</div>
        </div>
        
        <div class="mb-3 col-md-8">
            <label for="image" class="form-label">Image</label>
            <input placeholder="Upload Image" name="listing[image]" type="file" class="form-control">
            <div class="invalid-feedback"> give the image</div>
        </div>
        </div>
        
        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input placeholder="give location" name="listing[location]" type="text" class="form-control" required>
            <div class="invalid-feedback"> give the location</div>
        </div>
        
        <div class="mb-3">
            <label for="country" class="form-label">Country</label>
            <input placeholder="give country" name="listing[country]" type="text" class="form-control" required>
            <div class="invalid-feedback"> give the country</div>
        </div>
        
        <br>
        <button class="btn btn-dark">add</button>
        <br>
        <br>
    </form>
    </div>
    </div>
</body>